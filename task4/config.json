{
  "model": {
    "name": "cognitivecomputations/dolphin-2.9-llama3-8b",
    "quantization": "QLoRA 4-bit NF4",
    "dtype": "bfloat16"
  },
  "lora": {
    "r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "bias": "none",
    "task_type": "CAUSAL_LM"
  },
  "training": {
    "epochs": 3,
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 8,
    "effective_batch_size": 32,
    "learning_rate": 2e-4,
    "lr_scheduler": "cosine",
    "warmup_ratio": 0.05,
    "max_seq_length": 512,
    "bf16": true,
    "seed": 42
  },
  "dataset": {
    "total": 1000,
    "train": 800,
    "validation": 100,
    "test": 100,
    "attack_class": "C5",
    "format": "alpaca_instruction"
  }
}
